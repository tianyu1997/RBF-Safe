@PACKAGE_INIT@
include("${CMAKE_CURRENT_LIST_DIR}/RBFSafeTargets.cmake")

set(RBFSafe_ompl_FOUND FALSE)
if("ompl" IN_LIST RBFSafe_FIND_COMPONENTS)
    if(@RBFSAFE_OMPL_BUILT@)
        include(CMakeFindDependencyMacro)
        find_dependency(ompl CONFIG)
        if(NOT TARGET ompl::ompl)
            if(NOT OMPL_INCLUDE_DIRS OR NOT OMPL_LIBRARIES)
                set(RBFSafe_ompl_NOT_FOUND_MESSAGE
                    "OMPL did not provide ompl::ompl or legacy include/library variables")
            else()
                set(_RBFSafe_ompl_include_dirs "")
                foreach(_RBFSafe_ompl_include_dir IN LISTS OMPL_INCLUDE_DIRS)
                    if(EXISTS "${_RBFSafe_ompl_include_dir}")
                        list(APPEND _RBFSafe_ompl_include_dirs "${_RBFSafe_ompl_include_dir}")
                    endif()
                endforeach()
                add_library(ompl::ompl INTERFACE IMPORTED)
                set_target_properties(ompl::ompl PROPERTIES
                    INTERFACE_INCLUDE_DIRECTORIES "${_RBFSafe_ompl_include_dirs}"
                    INTERFACE_LINK_LIBRARIES "${OMPL_LIBRARIES}")
            endif()
        endif()
        if(TARGET ompl::ompl)
            include("${CMAKE_CURRENT_LIST_DIR}/RBFSafeOmplTargets.cmake")
            set(RBFSafe_ompl_FOUND TRUE)
        endif()
    else()
        set(RBFSafe_ompl_NOT_FOUND_MESSAGE "RBFSafe was installed without the optional OMPL adapter")
    endif()
endif()
check_required_components(RBFSafe)
